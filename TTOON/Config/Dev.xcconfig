//환경
ENV = dev

//앱 이름
NAME = TN-dev

//버전
APP_VERSION = 1.0

//앱 이름 + 버전
APP_NAME = $(NAME) ($(APP_VERSION))

//번들 ID
BUNDLE_IDENTIFIER = com.TTOON.dev

//Base URL
BASE_URL = 
